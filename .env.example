APP_NAME=Lead Enrichment Local
DEBUG_MODE=true
DATABASE_URL=sqlite:///./lead_enrichment.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
DEFAULT_ENRICHMENT_MODEL=qwen3:14b
DEFAULT_SCHEMA_INFERENCE_MODEL=qwen3-coder:30b
DEFAULT_QUERY_GENERATION_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=45
REQUEST_TIMEOUT_SECONDS=20

# Lead discovery (directory scrapers; OSM = fallback)
DISCOVERY_ENABLE_YELP_DIRECTORY=true
DISCOVERY_ENABLE_YELLOWPAGES_DIRECTORY=true
DISCOVERY_ENABLE_OSM_FALLBACK=true
DISCOVERY_ENABLE_GOOGLE_PLACES=false
DISCOVERY_ENABLE_YELP_FUSION_API=false
DISCOVERY_YELP_MAX_PAGES=5
DISCOVERY_YELLOWPAGES_MAX_PAGES=5
DISCOVERY_YELP_FETCH_DETAIL=true
DISCOVERY_YELLOWPAGES_FETCH_DETAIL=true
DISCOVERY_PARALLEL_WORKERS=3
DISCOVERY_BATCH_COMMIT_SIZE=150
DISCOVERY_OSM_USER_AGENT=lead-enrichment-local/1.0
